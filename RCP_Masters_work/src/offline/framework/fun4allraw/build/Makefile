install-decoderincludeHEADERS: $(decoderinclude_HEADERS)
	@$(NORMAL_INSTALL)
	@list='$(decoderinclude_HEADERS)'; test -n "$(decoderincludedir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(decoderincludedir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(decoderincludedir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_HEADER) $$files '$(DESTDIR)$(decoderincludedir)'"; \
	  $(INSTALL_HEADER) $$files "$(DESTDIR)$(decoderincludedir)" || exit $$?; \
	done

uninstall-decoderincludeHEADERS:
